# ============================================
# IP-Track Network Monitor Configuration
# ============================================

# ============================================
# Application Settings
# ============================================
APP_NAME=IP-Track Network Monitor
APP_VERSION=2.2.0
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8100
API_V1_PREFIX=/api/v1

# CORS Origins (JSON array format)
# Add your frontend URLs here
BACKEND_CORS_ORIGINS=["http://localhost:8001","http://localhost:3000"]

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# REQUIRED: Set a secure password
DATABASE_USER=iptrack
DATABASE_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=iptrack

# Connection Pool Settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO_SQL=false

# ============================================
# Redis Cache Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=300
REDIS_ENABLED=true

# ============================================
# Security Configuration
# ============================================
# REQUIRED: Generate with: python scripts/generate_key.py
# Or: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_ME_WITH_FERNET_KEY_GENERATOR

# ============================================
# Network Collection Scheduler
# ============================================
COLLECTION_ENABLED=true
COLLECTION_INTERVAL_MINUTES=120
IPAM_SCAN_INTERVAL_MINUTES=60
OPTICAL_MODULE_INTERVAL_MINUTES=720
ALARM_CLEANUP_HOUR=3
ALARM_RETENTION_DAYS=30

# ============================================
# IPAM Configuration
# ============================================
# Hours without response before marking IP as offline
# Prevents temporary network issues from marking IPs as offline
IPAM_OFFLINE_THRESHOLD_HOURS=6

# ============================================
# Worker Pool Sizes
# ============================================
# Adjust based on network size and server resources
COLLECTION_WORKERS=10
IP_LOOKUP_WORKERS=50
DISCOVERY_WORKERS=20
IPAM_SCAN_WORKERS=20

# ============================================
# Batch Processing Configuration
# ============================================
COLLECTION_BATCH_SIZE=5
OPTICAL_BATCH_SIZE=3
COLLECTION_MAX_RETRIES=3
COLLECTION_RETRY_BACKOFF=2

# ============================================
# Timeouts (seconds)
# ============================================
DEFAULT_SSH_TIMEOUT=30
CLI_COMMAND_TIMEOUT=60
SNMP_TIMEOUT=10
CONNECTION_TIMEOUT=30
COLLECTION_JOB_TIMEOUT=300

# ============================================
# Port Analysis Thresholds
# ============================================
PORT_SINGLE_MAC_CONFIDENCE=95
PORT_TRUNK_THRESHOLD=10
PORT_UPLINK_THRESHOLD=50
PORT_MAX_MAC_ACCESS=10

# ============================================
# IP Location Confidence Scoring
# ============================================
IP_LOCATION_BASE_SCORE=50
IP_LOCATION_SINGLE_MAC_BONUS=30
IP_LOCATION_ACCESS_PORT_BONUS=25
IP_LOCATION_TRUNK_PENALTY=35

# ============================================
# SNMP Configuration
# ============================================
SNMP_VERSION=3
SNMP_PORT=161
SNMP_RETRIES=3
SNMP_COMMUNITY=

# ============================================
# Vendor-Specific Collection Strategies
# ============================================
# Cisco
CISCO_PRIMARY_METHOD=cli
CISCO_FALLBACK_METHOD=snmp
CISCO_ENABLE_REQUIRED=true

# Dell
DELL_PRIMARY_METHOD=cli
DELL_FALLBACK_METHOD=snmp
DELL_ENABLE_REQUIRED=true

# Alcatel/Nokia
ALCATEL_PRIMARY_METHOD=cli
ALCATEL_FALLBACK_METHOD=
ALCATEL_ENABLE_REQUIRED=false

# Juniper
JUNIPER_PRIMARY_METHOD=cli
JUNIPER_FALLBACK_METHOD=snmp
JUNIPER_ENABLE_REQUIRED=false

# ============================================
# Feature Toggles
# ============================================
FEATURE_IPAM=true
FEATURE_ALARMS=true
FEATURE_OPTICAL_MODULES=true
FEATURE_PORT_ANALYSIS=true
FEATURE_STATUS_CHECKER=true
FEATURE_QUERY_HISTORY=true

# ============================================
# Logging Configuration
# ============================================
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/iptrack.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# ============================================
# Docker Port Mappings (docker-compose only)
# ============================================
POSTGRES_PORT=5432
BACKEND_PORT=8101
FRONTEND_PORT=8001

# ============================================
# Optional: Build-time Proxy (for corporate networks)
# ============================================
# Uncomment if behind a corporate proxy
# PIP_PROXY=http://proxy.example.com:8080
